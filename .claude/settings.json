{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf ..)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.ssh/**)",
      "Bash(cat *.env)",
      "Bash(cat *.env.*)",
      "Bash(find ~/*)"
    ],
    "ask": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git rebase *)",
      "Bash(git branch -D *)",
      "Bash(git branch -d *)"
    ],
    "allow": [
      "Read(**)",
      "Edit(**)",
      "WebFetch(*)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(git stash list *)",
      "Bash(git tag *)",
      "Bash(git describe *)",
      "Bash(git shortlog *)",
      "Bash(git blame *)",
      "Bash(git ls-files *)",
      "Bash(git ls-tree *)",
      "Bash(git *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh repo *)",
      "Bash(gh run *)",
      "Bash(gh api *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(tsc *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(vitest *)",
      "Bash(playwright *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find ./*)",
      "Bash(which *)",
      "Bash(echo *)"
    ]
  }
}
